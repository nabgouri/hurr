<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base: deep dark warm -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#0D0A15"
                android:centerColor="#1A1225"
                android:endColor="#100B1A"
                android:angle="270" />
        </shape>
    </item>
    <!-- Radial glow: amber haze -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:startColor="#0DF59E0B"
                android:endColor="#00000000"
                android:gradientRadius="360dp"
                android:centerX="0.5"
                android:centerY="0.35" />
        </shape>
    </item>
</layer-list>
