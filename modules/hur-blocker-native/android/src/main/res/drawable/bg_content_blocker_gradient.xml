<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base: deep dark navy -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#060D18"
                android:centerColor="#0C1A2E"
                android:endColor="#0A1225"
                android:angle="270" />
        </shape>
    </item>
    <!-- Radial glow: subtle warm spotlight from center-top -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:startColor="#1A1E3A4D"
                android:endColor="#00000000"
                android:gradientRadius="480dp"
                android:centerX="0.5"
                android:centerY="0.35" />
        </shape>
    </item>
    <!-- Accent glow: very subtle teal haze at center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:startColor="#0D2DD4BF"
                android:endColor="#00000000"
                android:gradientRadius="360dp"
                android:centerX="0.5"
                android:centerY="0.38" />
        </shape>
    </item>
</layer-list>
